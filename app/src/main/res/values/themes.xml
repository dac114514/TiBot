<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TiBot" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- P1 #11 新增：Splash 主题（启动时使用，installSplashScreen() 后自动切到 Theme.TiBot） -->
    <style name="Theme.TiBot.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.TiBot</item>
    </style>
</resources>
